# ── API (api/) ──────────────────────────────────────────────────────────────
# Copy to api/.env for local dev. In Azure, set these on the Container App.

# Service name (shown in /health and logs).
APP_NAME=fi-template-api

# Public API gate. Unset → fail-open (dev). Set in production; the web build
# must send the same value as NEXT_PUBLIC_API_KEY.
APP_API_KEY=

# Feature flags — which optional capabilities this app ships (comma list,
# case-insensitive). The chat assistant is always on. Known: cms, marketplace.
# Unset → chat only. The web build must mirror this in NEXT_PUBLIC_APP_MODULES.
APP_MODULES=

# Agent backend: claude | codex. Defaults to claude.
APP_BACKEND=claude
APP_MODEL=claude-sonnet-4-5
APP_MODEL_CODEX=gpt-4.1

# Claude backend (Max subscription): the OAuth token the SDK materializes into
# ~/.claude/.credentials.json. Generate with `claude setup-token`.
CLAUDE_CODE_OAUTH_TOKEN=

# Codex backend (Azure OpenAI motor): required only if APP_BACKEND=codex.
AZURE_OPENAI_ENDPOINT=

# CORS — comma-separated origins. Unset → "*" (dev). Lock to the SWA URL in prod.
CORS_ALLOW_ORIGINS=

# Optional tuning (defaults shown).
# APP_CHAT_TURN_TIMEOUT_S=600
# APP_SSE_HEARTBEAT_S=15
# APP_REQUEST_TEXT_MAX_CHARS=12000

# Optional RAG (only if you pass a corpus_id to /chat/stream). hdf5 for local
# single-process; pgvector for multi-replica (see infra/docker-compose.dev.yml).
# FI_RAG_BACKEND=hdf5
# FI_RAG_PGVECTOR_DSN=postgresql://app:app@127.0.0.1:5433/app
# FI_RAG_EMBED_DIM=256

# ── Web (web/) ────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_* is inlined at BUILD time. Set before `next build`.
# NEXT_PUBLIC_API_URL=http://localhost:8080
# NEXT_PUBLIC_API_KEY=
# Mirror of APP_MODULES for the front (same comma list). Disabled features'
# UIs are dynamically imported, so they never ship in the bundle.
# NEXT_PUBLIC_APP_MODULES=
